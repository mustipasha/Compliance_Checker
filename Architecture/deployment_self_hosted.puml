@startuml Self_Hosted_Deployment_Architecture
title Detailed Deployment View: Workstation (Local + PM2)

skinparam componentStyle uml2
skinparam node {
    BackgroundColor White
    BorderColor black
}

actor "User (Local Browser)" as LocalUser
actor "User (Remote/Tunnel)" as RemoteUser

package "User's Workstation (MacBook Air)" {
    node "Process Manager (PM2)" #GhostWhite {
        component "Frontend Service" #AliceBlue {
            [Vite Dev Server (Port 5173)]
        }
        component "Backend Service" #PaleGreen {
            [API (main.py)]
            [Ingestion (Chromadb)]
            [Orchestrator (pipeline.py)]
        }
        
        node "Multi-Agent Pipeline" #GhostWhite {
            component "Alignment Agent" as Agent1
            component "Gap Agent" as Agent2
            component "Synthesis Agent" as Agent3
        }
    }

    node "File System" #White {
        database "Persistent Local Storage" as Storage {
            folder "uploaded_files/"
            folder "chroma_db/"
            folder "assessment_history/"
        }
        artifact "Criteria Files (.json)" as Criteria
    }

    node "Local Inference Engine" <<Service>> as OllamaNode {
        component "Ollama (Local Models)" as Ollama
    }
}

cloud "Pinggy/Tunnel (Optional)" {
    interface "https://mustipasha.pinggy.link" as TunnelURL
}

node "LLM Providers (External)" as APIs {
    component "OpenAI (gpt-5-nano)" as OpenAI
    component "Anthropic (Claude 4.6)" as Anthropic
    component "Google (Gemini 3)" as Google
}

' Interactions
RemoteUser -down-> TunnelURL : HTTPS
TunnelURL -down-> [Vite Dev Server (Port 5173)] : Secure Tunnel

LocalUser -down-> [Vite Dev Server (Port 5173)] : localhost:5173
[Vite Dev Server (Port 5173)] -right-> [API (main.py)] : API Requests (localhost:8000)

[Orchestrator (pipeline.py)] -down-> [Ingestion (Chromadb)] : Retrieve Context
[Orchestrator (pipeline.py)] -down-> Agent1 : Step 1: Align
[Orchestrator (pipeline.py)] -down-> Agent2 : Step 2: Gap
[Orchestrator (pipeline.py)] -down-> Agent3 : Step 3: Synthesis

Agent1 -right-> APIs : API Requests
Agent2 -right-> APIs : API Requests
Agent3 -right-> APIs : API Requests

[API (main.py)] -down-> Storage : Persistent I/O & DB
[API (main.py)] -down-> Criteria : Read Definitions
[API (main.py)] -right-> Ollama : Local Reasoning

note bottom of Storage
  **Major Advantage**:
  Everything is stored on your local disk.
  No data is lost when you stop the app.
end note

@enduml
